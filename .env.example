# Copy to .env and edit if needed.

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# JWT signing key - CHANGE THIS in any non-toy environment.
JWT_SECRET=change-me-please-use-a-long-random-string

# Logging level for all services: debug | info | warn | error
LOG_LEVEL=info

# Grafana login.
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
