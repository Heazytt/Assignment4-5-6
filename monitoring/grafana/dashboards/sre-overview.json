{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "title": "SRE Microservices — Overview & Capacity",
  "uid": "sre-overview",
  "version": 2,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["sre", "microservices", "capacity"],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Services UP",
      "id": 1,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "service_up", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "value_and_name" }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests / s by service",
      "id": 2,
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total[1m]))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx error rate by service",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[1m]))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 HTTP latency (s)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "Capacity & Resources",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU usage per container (cores)",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        { "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]))", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "type": "timeseries",
      "title": "Memory usage per container (MB)",
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        { "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "type": "timeseries",
      "title": "Network I/O per container (B/s)",
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        { "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[1m]))", "legendFormat": "{{name}} RX", "refId": "A" },
        { "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[1m]))", "legendFormat": "{{name}} TX", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "type": "stat",
      "title": "Host CPU (%)",
      "id": 13,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 25 },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": 0 }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }
      ]}}}
    },
    {
      "type": "stat",
      "title": "Host RAM (%)",
      "id": 14,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 25 },
      "targets": [
        { "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }
      ]}}}
    },
    {
      "type": "row",
      "title": "Business Operations",
      "id": 200,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Business operations rate",
      "id": 20,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "targets": [
        { "expr": "sum by (service, operation, result) (rate(business_operations_total[1m]))", "legendFormat": "{{service}}: {{operation}} ({{result}})", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "External calls (gRPC / RabbitMQ)",
      "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "targets": [
        { "expr": "sum by (service, target, result) (rate(external_calls_total[1m]))", "legendFormat": "{{service}} -> {{target}} ({{result}})", "refId": "A" }
      ]
    }
  ]
}
